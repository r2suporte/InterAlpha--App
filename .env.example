# 🔧 Configuração de Variáveis de Ambiente - InterAlpha App
# Copie este arquivo para .env.local e configure suas credenciais

# 🗄️ Database (Obrigatório)
# PostgreSQL connection string para Neon Database
# Formato: postgresql://username:password@host.neon.tech/database?sslmode=require
DATABASE_URL="postgresql://username:password@host.neon.tech/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://username:password@host.neon.tech/database?sslmode=require&channel_binding=require"

# 🔐 Autenticação - Clerk (Obrigatório para autenticação de funcionários)
# Chaves do Clerk para autenticação
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# 🔑 NextAuth Secret (Obrigatório)
# Chave secreta para NextAuth (gere uma string aleatória)
NEXTAUTH_SECRET="your-secret-key-here"



# 💳 Pagamentos - Stripe (Opcional)
# Chaves do Stripe para processamento de pagamentos
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# 📱 SMS/WhatsApp - Twilio (Opcional)
# Credenciais do Twilio para envio de SMS e WhatsApp
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# 📱 WhatsApp Business API (Opcional)
# Configurações para integração com WhatsApp Business
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"
# Variáveis alternativas usadas no código
WA_PHONE_NUMBER_ID="your-phone-number-id"
CLOUD_API_ACCESS_TOKEN="your-whatsapp-access-token"
CLOUD_API_VERSION="v18.0"
WA_BASE_URL="https://graph.facebook.com"

# 📧 Email - Nodemailer (Opcional)
# Configurações SMTP para envio de emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@interalpha.com"

# 📅 Google Calendar (Opcional)
# Credenciais OAuth2 do Google para integração com Calendar
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# 🔄 Redis - Cache e Filas (Opcional)
# Configurações do Redis para sistema de filas e cache
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"
REDIS_CACHE_TTL_DEFAULT="300"
REDIS_CACHE_ENABLED="true"

# 💼 Sistema Contábil (Opcional)
# API para integração com sistema contábil
ACCOUNTING_API_URL="https://api.accounting-system.com"
ACCOUNTING_API_KEY="your-accounting-api-key"

# 💾 Backup (Opcional)
# Configurações para sistema de backup
BACKUP_STORAGE_PATH="./backups"
BACKUP_RETENTION_DAYS="30"

# 🔧 Ambiente
NODE_ENV="development"
